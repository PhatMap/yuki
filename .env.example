# Yuki runs locally without any environment variables.
# Leave these unset for the default local-first development mode.

# IMPORTANT:
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Do not put private API keys, provider secrets, service-role keys,
# Redis tokens, or worker secrets in NEXT_PUBLIC_* variables.

# mock | gemini-proxy | ollama
NEXT_PUBLIC_AI_RUNTIME=mock
# Fresh installs can stay in mock mode until GEMINI_API_KEY is configured.

# indexed-db | supabase
NEXT_PUBLIC_STORAGE_RUNTIME=indexed-db

# local-browser | local-worker | cloud-queue
NEXT_PUBLIC_JOB_RUNTIME=local-browser

# Optional public proxy URL.
# This is only the public endpoint URL (default app route: /api/ai/gemini).
# Do not put API keys here.
NEXT_PUBLIC_AI_PROXY_ENDPOINT=

# Recommended real-AI local setup (when you are ready):
# NEXT_PUBLIC_AI_RUNTIME=gemini-proxy
# NEXT_PUBLIC_AI_PROXY_ENDPOINT=/api/ai/gemini
# GEMINI_API_KEY=<server-only key in .env.local>

# Server-only placeholders for future backend / worker / proxy usage.
# Real values belong in .env.local, deployment platform env settings,
# or a team password manager. Do not commit real secrets.

# AI provider secrets (server-only)
AI_PROVIDER_API_KEY=

# Gemini Proxy server adapter:
# google-generative-language = official Google Gemini REST using GEMINI_API_KEY
# openai-compatible = external OpenAI-compatible Gemini proxy using
# GEMINI_PROXY_BASE_URL + GEMINI_PROXY_API_KEYS
GEMINI_PROXY_ADAPTER=google-generative-language

# Official Google Gemini server route.
# Required when adapter is google-generative-language.
# Supports multiple keys (comma/newline separated).
# Put in .env.local (or deploy env), never in NEXT_PUBLIC_* variables.
GEMINI_API_KEY=

# OpenAI-compatible proxy mode (adapter=openai-compatible):
# GEMINI_PROXY_BASE_URL=https://your-openai-compatible-proxy.example
# GEMINI_PROXY_API_KEYS=sk-key-1,sk-key-2
# Do not put GEMINI_PROXY_API_KEYS in NEXT_PUBLIC_* variables.
# Browser diagnostics expose keyCount only, never raw keys.
# GEMINI_PROXY_BASE_URL=
# GEMINI_PROXY_API_KEYS=

OPENAI_API_KEY=
OLLAMA_BASE_URL=

# Supabase future integration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / Upstash future integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare future worker/queue integration
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
