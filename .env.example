# Yuki runs locally without any environment variables.
# Leave these unset for the default local-first development mode.

# IMPORTANT:
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Do not put private API keys, provider secrets, service-role keys,
# Redis tokens, or worker secrets in NEXT_PUBLIC_* variables.

# mock | gemini-proxy | ollama
NEXT_PUBLIC_AI_RUNTIME=mock

# indexed-db | supabase
NEXT_PUBLIC_STORAGE_RUNTIME=indexed-db

# local-browser | local-worker | cloud-queue
NEXT_PUBLIC_JOB_RUNTIME=local-browser

# Optional public proxy URL.
# This is only the endpoint URL. Do not put API keys here.
NEXT_PUBLIC_AI_PROXY_ENDPOINT=

# Server-only placeholders for future backend / worker / proxy usage.
# Real values belong in .env.local, deployment platform env settings,
# or a team password manager. Do not commit real secrets.

# AI provider secrets
AI_PROVIDER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=

# Supabase future integration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / Upstash future integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare future worker/queue integration
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=